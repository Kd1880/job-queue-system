# .env.example
# ------------------
# Template documenting every environment variable the system expects.
# The real .env is gitignored (never committed). To run locally:
#
#   cp .env.example .env
#   docker-compose up
#
# The defaults below are safe local-dev values. In a real deployment you
# would fill in real values and source secrets from a manager (AWS Secrets
# Manager, Vault, etc.) rather than a file.

# Postgres connection string (host "postgres" = the docker-compose service name)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/jobqueue

# Redis connection string (host "redis" = the docker-compose service name)
REDIS_URL=redis://redis:6379

# Uvicorn bind address inside the api container
API_HOST=0.0.0.0
API_PORT=8000

# Retry attempts before a failed job is moved to the dead_letter_queue
MAX_RETRIES=3

# Seconds the worker's BRPOP blocks before looping to check for shutdown
WORKER_TIMEOUT=5

# Gmail SMTP (Phase 2, send_email handler). EMAIL_PASSWORD must be a Gmail
# App Password (myaccount.google.com/apppasswords) — NOT your main password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# Max job submissions per user per minute (Phase 2 rate limiter —
# api/middleware/rate_limiter.py). Over-limit requests get HTTP 429.
RATE_LIMIT_PER_MINUTE=5

# Number of parallel worker processes the pool runs (worker/worker_pool.py).
WORKER_COUNT=3
